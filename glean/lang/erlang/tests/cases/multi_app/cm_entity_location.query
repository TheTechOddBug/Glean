query: |
  Result where
    codemarkup.erlang.ErlangEntityLocation {
      entity = RawEntity,
      location = {
        name = LocationName,
        file = LocationFile,
        location = { span = LocationSpan }
      }
    };
    src.File LocationFileKey = LocationFile;
    (
      { decl = Decl } = RawEntity;
      Entity = {
        decl = { just = Decl },
        macro_usage = nothing,
        var_ = nothing
      };
    ) | (
      { macro_usage = Usage } = RawEntity;
      (
        erlang.MacroUsage {
          name = MacroName,
          module = MacroModule,
          arity = { just = MacroArity },
          app = MacroApp
        } = Usage;
        Entity = {
          decl = nothing,
          macro_usage = { just = {
            key = {
              app = MacroApp,
              arity = { just = MacroArity },
              module = MacroModule,
              name = MacroName
            }
          } },
          var_ = nothing
        };
      ) | (
        erlang.MacroUsage {
          name = MacroName,
          module = MacroModule,
          arity = nothing,
          app = MacroApp
        } = Usage;
        Entity = {
          decl = nothing,
          macro_usage = { just = {
            key = {
              app = MacroApp,
              arity = nothing,
              module = MacroModule,
              name = MacroName
            }
          } },
          var_ = nothing
        };
      );
    ) | (
      { var_ = Var } = RawEntity;
      erlang.VarDeclaration {
        name = VarName,
        module = VarModule,
        app = VarApp,
        span_start = VarSpanStart
      } = Var;
      Entity = {
        decl = nothing,
        macro_usage = nothing,
        var_ = { just = {
          key = {
            app = VarApp,
            module = VarModule,
            name = VarName,
            span_start = VarSpanStart
          }
        } }
      };
    );
    Result = {
      entity = Entity,
      location = {
        file = { key = LocationFileKey },
        location = { span = LocationSpan },
        name = LocationName
      }
    };
perf: true
transform: [normord, []]
