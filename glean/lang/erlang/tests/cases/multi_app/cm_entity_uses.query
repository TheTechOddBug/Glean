query: |
  Result where
    codemarkup.erlang.ErlangEntityUses {
      target = RawTarget,
      file = UsageFile,
      span = UsageSpan
    };
    src.File UsageFileKey = UsageFile;
    (
      { decl = Decl } = RawTarget;
      Target = {
        decl = { just = Decl },
        macro_usage = nothing,
        var_ = nothing
      };
    ) | (
      { macro_usage = Usage } = RawTarget;
      (
        erlang.MacroUsage {
          name = MacroName,
          module = MacroModule,
          arity = { just = MacroArity },
          app = MacroApp
        } = Usage;
        Target = {
          decl = nothing,
          macro_usage = { just = {
            key = {
              app = MacroApp,
              arity = { just = MacroArity },
              module = MacroModule,
              name = MacroName
            }
          } },
          var_ = nothing
        };
      ) | (
        erlang.MacroUsage {
          name = MacroName,
          module = MacroModule,
          arity = nothing,
          app = MacroApp
        } = Usage;
        Target = {
          decl = nothing,
          macro_usage = { just = {
            key = {
              app = MacroApp,
              arity = nothing,
              module = MacroModule,
              name = MacroName
            }
          } },
          var_ = nothing
        };
      );
    ) | (
      { var_ = Var } = RawTarget;
      erlang.VarDeclaration {
        name = VarName,
        module = VarModule,
        app = VarApp,
        span_start = VarSpanStart
      } = Var;
      Target = {
        decl = nothing,
        macro_usage = nothing,
        var_ = { just = {
          key = {
            app = VarApp,
            module = VarModule,
            name = VarName,
            span_start = VarSpanStart
          }
        } }
      };
    );
    Result = {
      file = { key = UsageFileKey },
      span = UsageSpan,
      target = Target
    };
perf: true
transform: [normord, []]
